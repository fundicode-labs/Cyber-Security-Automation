# Copy this file to .env (or configure these variables in your server environment)
# Values here override DB settings for payment live configuration.

# Mix by YAS
CSA_MIXBYYAS_ENDPOINT=https://api-sandbox.mixbyyas.example/payments
CSA_MIXBYYAS_API_KEY=replace_with_mixbyyas_api_key
CSA_MIXBYYAS_WEBHOOK_SECRET=replace_with_mixbyyas_webhook_secret
CSA_MIXBYYAS_ALLOWED_IPS=196.10.10.10,196.10.10.11

# HaloPesa
CSA_HALOPESA_ENDPOINT=https://api-sandbox.halopesa.example/collections
CSA_HALOPESA_API_KEY=replace_with_halopesa_api_key
CSA_HALOPESA_WEBHOOK_SECRET=replace_with_halopesa_webhook_secret
CSA_HALOPESA_ALLOWED_IPS=197.20.20.10,197.20.20.11

# Callback replay/timestamp protection window (seconds)
CSA_PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
